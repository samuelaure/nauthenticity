version: '3.8'

# Override configuration for local development
# Copy this file to docker-compose.override.yml and uncomment/edit as needed

services:
  app:
    # Example: Connect to shared infrastructure
    # environment:
    #   - DATABASE_URL=postgresql://user:pass@shared_postgres:5432/nauthenticity?schema=public
    #   - REDIS_HOST=shared_redis
    
    
    # If using shared mesh network:
    # networks:
    #   - shared-mesh
    
  # Disable local services to save resources when using shared infrastructure
  postgres:
    profiles: ["disabled"]
  
  redis:
    profiles: ["disabled"]

# networks:
#   shared-mesh:
#     external: true
