generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Post {
  id              String   @id @default(uuid())
  instagramId     String?  @unique
  instagramUrl    String   @unique
  username        String?
  igProfile       IgProfile? @relation(fields: [username], references: [username])
  caption         String?
  originalCaption String?
  postedAt        DateTime
  likes           Int      @default(0)
  comments        Int      @default(0)
  views           Int?
  engagementScore Float?

  collaborators   Json?
  intelligence    Json?

  runId           String?
  run             ScrapingRun? @relation(fields: [runId], references: [id])

  media           Media[]
  transcripts     Transcript[]
  feedbacks       CommentFeedback[]
  inspoItems      InspoItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
}

model IgProfile {
  username        String   @id
  profileImageUrl String?
  lastScrapedAt   DateTime @default(now())

  posts           Post[]
  brandTargets    BrandTarget[]
}

model ScrapingRun {
  id          String   @id @default(uuid())
  username    String
  actorRunId  String?  @unique
  datasetId   String?
  rawData     Json?
  status      String   @default("completed")
  phase       String   @default("finished")
  isPaused    Boolean  @default(false)

  posts       Post[]

  createdAt   DateTime @default(now())
}

model Media {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  type        String
  url         String?
  storageUrl    String
  thumbnailUrl  String?
  duration      Float?
  index       Int      @default(0)

  transcript  Transcript?

  createdAt   DateTime @default(now())
}

model Transcript {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id])

  mediaId     String?  @unique
  media       Media?   @relation(fields: [mediaId], references: [id])

  text        String
  originalText String?
  json        Json?

  createdAt    DateTime @default(now())
  embedding    Embedding?
}

model Embedding {
  id           String     @id @default(uuid())
  transcriptId String     @unique
  transcript   Transcript @relation(fields: [transcriptId], references: [id])
  vector       Unsupported("vector(1536)")
  model        String     @default("text-embedding-3-small")
  createdAt    DateTime   @default(now())
}

model Brand {
  id               String   @id @default(uuid())
  workspaceId      String   // Platform workspace ID from 9naŭ
  brandName        String
  voicePrompt      String   @db.Text  // Brand DNA — primary personality prompt
  commentStrategy  String?  @db.Text
  suggestionsCount Int      @default(3)

  windowStart      String?
  windowEnd        String?
  timezone         String   @default("UTC")

  isActive         Boolean  @default(true)
  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?

  inspoRequestCount Int     @default(0)

  targets          BrandTarget[]
  feedbacks        CommentFeedback[]
  inspoItems       InspoItem[]
  syntheses        BrandSynthesis[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BrandSynthesis {
  id           String  @id @default(uuid())
  brandId      String
  brand        Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  type         String
  content      String  @db.Text
  attachedUrls Json    @default("[]")
  createdAt    DateTime @default(now())

  @@index([brandId, type])
}

model BrandTarget {
  id               String    @id @default(uuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id])
  username         String
  igProfile        IgProfile @relation(fields: [username], references: [username])
  profileStrategy  String?   @db.Text

  createdAt        DateTime @default(now())

  @@unique([brandId, username])
}

model CommentFeedback {
  id           String  @id @default(uuid())
  brandId      String
  brand        Brand   @relation(fields: [brandId], references: [id])
  postId       String
  post         Post    @relation(fields: [postId], references: [id])
  commentText  String  @db.Text
  isSelected   Boolean @default(false)
  sentAt       DateTime @default(now())
}

model InspoItem {
  id              String  @id @default(uuid())
  brandId         String
  brand           Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?   @relation(fields: [postId], references: [id])
  type            String
  note            String? @db.Text
  status          String  @default("pending")
  extractedHook   String? @db.Text
  extractedTheme  String?
  adaptedScript   String? @db.Text
  injectedContext String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
