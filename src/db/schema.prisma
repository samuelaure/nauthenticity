generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Post {
  id              String   @id @default(uuid())
  instagramId     String?  @unique
  instagramUrl    String   @unique
  username        String?
  account         Account? @relation(fields: [username], references: [username])
  caption         String?
  originalCaption String?  // Stores original scraped caption if edited
  postedAt        DateTime
  likes           Int      @default(0)
  comments        Int      @default(0)
  views           Int?
  engagementScore Float?
  
  collaborators   Json?    // Stores collaborator info { username, profilePicUrl, role? }[]
  intelligence    Json?    // Stores extracted hooks, pillars, and CTA
  
  runId           String?
  run             ScrapingRun? @relation(fields: [runId], references: [id])

  media           Media[]
  transcripts     Transcript[]
  feedbacks       CommentFeedback[]
  inspoItems      InspoItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
}

model Account {
  username        String   @id
  profileImageUrl String?
  lastScrapedAt   DateTime @default(now())
  
  posts           Post[]
  brandTargets    BrandTarget[]
}

model ScrapingRun {
  id          String   @id @default(uuid())
  username    String
  actorRunId  String?  @unique
  datasetId   String?
  rawData     Json?    // Optional: store full JSON result for 24h fallback
  status      String   @default("completed") // "pending", "completed", "failed"
  phase       String   @default("finished")  // "scraping", "downloading", "optimizing", "visualizing", "profiling", "transcribing", "finished"
  isPaused    Boolean  @default(false)
  
  posts       Post[]
  
  createdAt   DateTime @default(now())
}

model Media {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  type        String   // "video" | "image"
  url         String?  // Original source URL (needed for resume)
  storageUrl    String   // Local path or R2 URL
  thumbnailUrl  String?  // Local path for fast preview
  duration      Float?
  index       Int      @default(0)

  transcript  Transcript?

  createdAt   DateTime @default(now())
}

model Transcript {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id])

  mediaId     String?  @unique
  media       Media?   @relation(fields: [mediaId], references: [id])

  text        String
  originalText String? // Stores original Whisper text if edited
  json        Json?    // Full Whisper response with timestamps
  
  createdAt    DateTime @default(now())
  embedding    Embedding?
}

model Embedding {
  id           String     @id @default(uuid())
  transcriptId String     @unique
  transcript   Transcript @relation(fields: [transcriptId], references: [id])
  vector       Unsupported("vector(1536)")
  model        String     @default("text-embedding-3-small")
  createdAt    DateTime   @default(now())
}

model BrandConfig {
  id               String   @id @default(uuid())
  userId           String   // Telegram ID del usuario naŭ
  brandName        String
  voicePrompt      String   @db.Text  // Brand DNA canónico — Level 1 del prompt
  commentStrategy  String?  @db.Text  // Intención global de comentarios — Level 2
  suggestionsCount Int      @default(3) // Cuántas sugerencias generar (configurable)

  // Ventana de actividad (sincronizada desde Zazŭ)
  windowStart      String?             // "HH:MM" — inicio de ventana activa del usuario
  windowEnd        String?             // "HH:MM" — fin de ventana activa del usuario
  timezone         String   @default("UTC")

  isActive         Boolean  @default(true)

  targets          BrandTarget[]
  feedbacks        CommentFeedback[]
  inspoItems       InspoItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BrandTarget {
  id               String       @id @default(uuid())
  brandId          String
  brand            BrandConfig  @relation(fields: [brandId], references: [id])
  username         String
  account          Account      @relation(fields: [username], references: [username])
  profileStrategy  String?      @db.Text  // Estrategia específica para este perfil — Level 3

  createdAt        DateTime @default(now())

  @@unique([brandId, username])
}

model CommentFeedback {
  id           String       @id @default(uuid())
  brandId      String
  brand        BrandConfig  @relation(fields: [brandId], references: [id])
  postId       String
  post         Post         @relation(fields: [postId], references: [id])
  commentText  String       @db.Text  // Sugerencia elegida por el usuario (isSelected=true) o JSON de sugerencias (isSelected=false)
  isSelected   Boolean      @default(false) // true = el usuario confirmó esta sugerencia; false = registro optimista de dedup
  sentAt       DateTime     @default(now())
}

model InspoItem {
  id              String      @id @default(uuid())
  brandId         String
  brand           BrandConfig @relation(fields: [brandId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?       @relation(fields: [postId], references: [id])
  type            String      // "inspo" or "replicate"
  note            String?     @db.Text
  status          String      @default("pending") // "pending", "processed", "used"
  extractedHook   String?     @db.Text
  extractedTheme  String?
  adaptedScript   String?     @db.Text // For "replicate" type — brand-adapted script
  injectedContext String?     @db.Text // Additional data (strategy docs, etc.)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
