# Application
NODE_ENV=development
PORT=3000

# Database Configuration
# Default points to the local project container defined in docker-compose.yml
DB_USER=nauthenticity_user
DB_PASSWORD=local_dev_password
DB_NAME=nauthenticity
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public"

# Infrastructure
PUBLIC_DOMAIN=localhost

# Redis
# Default points to the local project container defined in docker-compose.yml
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=local_dev_redis_password

# Security & Inter-Service Auth
NAU_SERVICE_KEY=secret_key_for_dev
FRONTEND_URL=http://localhost:3000

# External Services
APIFY_TOKEN=your_apify_token_here
APIFY_INSTAGRAM_UNIVERSAL_ACTOR_ID=samuelaure/nau-ig-actor
OPENAI_API_KEY=your_openai_api_key_here

# AI Processing
# Point to your local Whisper instance (infrastructure/whisper)
TRANSCRIPTION_URL=http://localhost:8000

# Feature Flags
# Set to true to pause compute queue processing
PAUSE_COMPUTE=false
