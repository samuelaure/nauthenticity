# Application
NODE_ENV=development
PORT=3000

# Database Configuration
DB_USER=nauthenticity_user
DB_PASSWORD=local_dev_password
DB_NAME=nauthenticity
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@shared_postgres:5432/${DB_NAME}?schema=public"

# Infrastructure
PUBLIC_DOMAIN=nauthenticity.localhost

# Redis
REDIS_HOST=shared_redis
REDIS_PORT=6379

# External Services
APIFY_TOKEN=your_apify_token_here
APIFY_INSTAGRAM_UNIVERSAL_ACTOR_ID=samuelaure/nau-ig-actor
OPENAI_API_KEY=your_openai_api_key_here
